# Database Configuration
DB_HOST=localhost
DB_NAME=zealarc_db
DB_USER=root
DB_PASS=

# Hostinger SMTP Configuration
# Create this email account in your Hostinger hPanel (e.g., contact@zealarc.com)
# and enter the credentials here. This file (.env) will NOT be uploaded to GitHub.
SMTP_USER=contact@zealarc.com
SMTP_PASS=your-email-password

# Environment (Set to false in production)
DEV_MODE=true
